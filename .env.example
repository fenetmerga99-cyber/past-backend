# Copy to .env and fill in your real Gemini key.

GEMINI_API_KEY=paste_your_key_here
GEMINI_MODEL=gemini-3.5-flash
PORT=5000

# Base64-encoded Firebase service account JSON (see README for how to get this).
# Required for the /api/publish-exam background flow, which writes directly to
# Firestore so results appear even after the teacher closes the tab.
FIREBASE_SERVICE_ACCOUNT_BASE64=paste_the_base64_string_here
